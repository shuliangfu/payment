{
  "name": "@dreamer/payment",
  "version": "1.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./adapters": "./src/adapters/mod.ts",
    "./adapters/stripe": "./src/adapters/stripe.ts",
    "./adapters/paypal": "./src/adapters/paypal.ts",
    "./adapters/alipay": "./src/adapters/alipay.ts",
    "./adapters/wechat": "./src/adapters/wechat.ts",
    "./adapters/apple-pay": "./src/adapters/apple-pay.ts",
    "./adapters/google-pay": "./src/adapters/google-pay.ts",
    "./adapters/unionpay": "./src/adapters/unionpay.ts",
    "./adapters/web3": "./src/adapters/web3.ts"
  },
  "imports": {
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.1.2",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.2.2",
    "@dreamer/test": "jsr:@dreamer/test@^1.2.3",
    "@dreamer/crypto": "jsr:@dreamer/crypto@^1.1.0",
    "@dreamer/logger": "jsr:@dreamer/logger@^1.1.0"
  },
  "tasks": {
    "test": "deno test -A tests/crypto.test.ts tests/currency.test.ts tests/mod.test.ts tests/reconciliation.test.ts tests/subscription.test.ts",
    "test:integration": "deno test -A tests/web3.test.ts",
    "test:node": "tsx --tsconfig tsconfig.json --test --test-force-exit tests/crypto.test.ts tests/currency.test.ts tests/mod.test.ts tests/reconciliation.test.ts tests/subscription.test.ts",
    "check": "deno check src/mod.ts",
    "lint": "deno lint src/ tests/",
    "fmt": "deno fmt src/ tests/"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "deno.json",
      "README.md",
      "LICENSE",
      "NOTICE"
    ],
    "exclude": [
      "tests/**",
      "**/*.test.ts",
      "contracts/**",
      "examples/**"
    ]
  },
  "nodeModulesDir": "auto",
  "minimumDependencyAge": 0
}
